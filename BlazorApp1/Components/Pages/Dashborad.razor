@page "/dashboard"
@using OperationalWorkspaceUI.UIState
@using OperationalWorkspaceUI.UIServices

@inject UIStateContainer StateContainer
@inject IWorkspaceApiService ApiService
@inject NavigationManager Nav

<div class="dashboard-viewport">
    @if (_isProcessing)
    {
        <div class="text-center my-5">
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <p class="small text-muted mt-2">Compiling Customer 360 overview profile...</p>
        </div>
    }
    else if (StateContainer.CurrentContextResponse != null)
    {
        var ctx = StateContainer.CurrentContextResponse;

        <!-- Premium Feature: Predictive Alert Recommendation Card -->
        <div class="alert alert-@ctx.RecommendedActionStyleMarker.ToLowerInvariant() border-0 p-2 mb-3 shadow-sm d-flex gap-2 align-items-start" style="font-size: 0.8rem; border-left: 4px solid var(--bs-@ctx.RecommendedActionStyleMarker.ToLowerInvariant()) !important;">
            <span class="mt-0.5">🎯</span>
            <div>
                <div class="fw-bold">Predictive System Vector</div>
                <div class="small mt-0.5 text-dark opacity-75">@ctx.SuggestedNextActionCard</div>
            </div>
        </div>

        <!-- Premium Feature: AI Executive Context Brief -->
        <div class="card mb-3 bg-white border-start border-primary border-4" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body p-2.5">
                <div class="d-flex align-items-center mb-1.5 fw-bold text-primary" style="font-size: 0.8rem;">
                    <span class="me-1">✨</span> AI Context Briefing summary
                </div>
                <p class="small text-muted mb-0 lh-base" style="font-size: 0.78rem; white-space: pre-line;">@ctx.AiExecutiveBrief</p>
            </div>
        </div>

        <!-- Master View Selector Grid Matrix -->
        <h6 class="text-secondary small fw-bold text-uppercase tracking-wider mb-2" style="font-size: 0.7rem; letter-spacing: 0.5px;">Navigation Workspace</h6>
        <div class="row g-2 mb-3">
            <div class="col-6">
                <button class="btn btn-white border w-100 text-center py-2.5 shadow-sm bg-white rounded text-decoration-none" @onclick='() => NavigateTo("/customer-snapshot")'>
                    <div style="font-size: 1.2rem;">🏢</div>
                    <div class="fw-bold mt-1 text-dark" style="font-size: 0.75rem;">ERP Snapshot</div>
                </button>
            </div>
            <div class="col-6">
                <button class="btn btn-white border w-100 text-center py-2.5 shadow-sm bg-white rounded text-decoration-none" @onclick='() => NavigateTo("/contacts")'>
                    <div style="font-size: 1.2rem;">👥</div>
                    <div class="fw-bold mt-1 text-dark" style="font-size: 0.75rem;">BP Contacts</div>
                </button>
            </div>
            <div class="col-6">
                <button class="btn btn-white border w-100 text-center py-2.5 shadow-sm bg-white rounded text-decoration-none" @onclick='() => NavigateTo("/documents")'>
                    <div style="font-size: 1.2rem;">📁</div>
                    <div class="fw-bold mt-1 text-dark" style="font-size: 0.75rem;">Documents</div>
                </button>
            </div>
            <div class="col-6">
                <button class="btn btn-white border w-100 text-center py-2.5 shadow-sm bg-white rounded text-decoration-none" @onclick='() => NavigateTo("/tasks")'>
                    <div style="font-size: 1.2rem;">📋</div>
                    <div class="fw-bold mt-1 text-dark" style="font-size: 0.75rem;">Tasks & Logs</div>
                </button>
            </div>
        </div>

        <!-- Global Administrative Actions Security Rule Blocks -->
        @if (StateContainer.UserRoleScope.Contains("Admin"))
        {
            <div class="border-top pt-2 mt-3">
                <button class="btn btn-dark btn-sm w-100 fw-bold" style="font-size: 0.75rem;" @onclick='() => NavigateTo("/ticket-report")'>
                    📊 Open Global Ticket Audit Registry
                </button>
            </div>
        }
    }
</div>

@code {
    private bool _isProcessing = true;

    protected override async Task OnInitializedAsync()
    {
        // Enforce Flux container lookup constraints to prevent duplicate network hits
        if (StateContainer.CurrentContextResponse != null)
        {
            _isProcessing = false;
            return;
        }

        try
        {
            var res = await ApiService.GetWorkspaceContextAsync(
                StateContainer.SenderEmail, StateContainer.SenderName,
                StateContainer.ActiveUserEmail, "MOCK_TOKEN"
            );
            if (res != null)
            {
                StateContainer.SetWorkspaceContextResponse(res);
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void NavigateTo(string route) => Nav.NavigateTo($"{route}{Nav.ToAbsoluteUri(Nav.Uri).Query}");
}

