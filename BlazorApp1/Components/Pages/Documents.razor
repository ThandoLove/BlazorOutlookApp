@page "/documents"
@using OperationalWorkspaceUI.UIState

@inject UIStateContainer StateContainer
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav

<div class="documents-pane">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
        <h6 class="m-0 fw-bold text-dark" style="font-size: 0.95rem;">📁 Multi-Format Document Engine</h6>
        <button class="btn btn-outline-secondary btn-sm py-0 px-2" style="font-size: 0.7rem;" @onclick="GoBack">Back</button>
    </div>

    @if (StateContainer.CurrentContextResponse?.RecentDocuments != null && StateContainer.CurrentContextResponse.RecentDocuments.Any())
    {
        <div class="list-group d-grid gap-1">
            @foreach (var doc in StateContainer.CurrentContextResponse.RecentDocuments)
            {
                <div class="list-group-item p-2.5 bg-white border rounded shadow-xs" style="font-size: 0.78rem;">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <span class="fw-bold text-dark">@doc.DocumentNumber</span>

                        <!-- Document Interaction Actions Panel Toolbar -->
                        <div class="d-flex gap-2">
                            <button class="btn btn-link text-primary p-0 m-0 border-0 text-decoration-none fw-bold" style="font-size: 0.72rem;" @onclick='() => ViewDocumentInline(doc.DocumentNumber)'>View</button>
                            <span class="text-muted">|</span>
                            <button class="btn btn-link text-success p-0 m-0 border-0 text-decoration-none fw-bold" style="font-size: 0.72rem;" @onclick='() => DirectAttachDocument(doc.DocumentNumber)'>📎 Attach</button>
                        </div>
                    </div>
                    <div class="d-flex w-100 justify-content-between align-items-center mt-1 text-muted" style="font-size: 0.72rem;">
                        <span>@doc.Type • @doc.Date.ToShortDateString()</span>
                        <span class="text-primary fw-bold">@doc.Amount.ToString("C")</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="p-3 text-center border rounded bg-white text-muted small">No structural sales or financial ledger files mapped to this contact.</div>
    }

    <!-- Premium Feature Integration: Decoupled Native Modal Document Viewer -->
    @if (_showModalViewer && !string.IsNullOrEmpty(_activeDocNo))
    {
        <div class="modal-viewer-overlay" @onclick="CloseViewer">
            <div class="modal-viewer-content" @onclick:stopPropagation="true">
                <div class="d-flex justify-content-between align-items-center p-2.5 bg-dark text-white rounded-top">
                    <span class="fw-bold small">📄 Document Frame Workspace: @_activeDocNo</span>
                    <button class="btn-close btn-close-white btn-sm" @onclick="CloseViewer"></button>
                </div>
                <!-- Browser-native data-stream projection frame to safely view invoices/orders directly inside Outlook -->
                <div class="flex-grow-1">
                    <iframe class="doc-stream-frame" src="api/customer/documents/@_activeDocNo/stream?useMocks=true"></iframe>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _showModalViewer = false;
    private string _activeDocNo = string.Empty;

    private void ViewDocumentInline(string docNo)
    {
        _activeDocNo = docNo;
        _showModalViewer = true;
    }

    private async Task DirectAttachDocument(string docNo)
    {
        // Compute the absolute live streaming API endpoint URL route mapping destination
        string apiSecureUrl = $"https://workspace.local{docNo}/stream?useMocks=true";
        await JSRuntime.InvokeVoidAsync("officeBridge.attachFileToActiveEmail", apiSecureUrl, $"{docNo}.pdf");
    }

    private void CloseViewer()
    {
        _showModalViewer = false;
        _activeDocNo = string.Empty;
    }

    private void GoBack() => Nav.NavigateTo($"/dashboard{Nav.ToAbsoluteUri(Nav.Uri).Query}");
}

