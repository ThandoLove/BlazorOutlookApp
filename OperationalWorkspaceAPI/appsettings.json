{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SageX3WorkspaceDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "SageX3Settings": {
    "BaseUrl": "https://workspace.local",
    "EndpointFolderName": "SEED",
    "UseMocks": true,
    "UseMockAuth": true,
    "HttpClientTimeoutSeconds": 15,
    "ClientId": "MOCK_CLIENT_ID",
    "ClientSecret": "MOCK_CLIENT_SECRET"
  },
  "SageOAuthConfig": {
    "AuthorizationEndpoint": "https://workspace.local/oauth/auth",
    "TokenEndpoint": "https://workspace.local/oauth/token",
    "UserProfileEndpoint": "https://workspace.local/oauth/profile",
    "RedirectUri": "https://workspace.local/login-popup.html"
  },
  "TicketPersistenceOptions": {
    "DatabaseDirectory": "C:\\ProgramData\\SageX3Workspace\\Data\\",
    "DatabaseFileName": "workspace_tickets.json"
  }
}
