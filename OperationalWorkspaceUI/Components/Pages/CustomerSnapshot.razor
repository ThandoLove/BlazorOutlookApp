@page "/customer-snapshot"
@using OperationalWorkspaceUI.UIState

@inject UIStateContainer StateContainer
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="snapshot-container">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
        <h6 class="m-0 fw-bold text-dark" style="font-size: 0.95rem;">🏢 ERP Financial Standing</h6>
        <button class="btn btn-outline-secondary btn-sm py-0 px-2" style="font-size: 0.7rem;" @onclick="GoBack">Back</button>
    </div>

    @if (StateContainer.CurrentContextResponse?.Customer != null)
    {
        var customer = StateContainer.CurrentContextResponse.Customer;

        <div class="card bg-white border-0 shadow-sm mb-3">
            <div class="card-body p-3">
                <h5 class="fw-bold text-dark mb-1" style="font-size: 0.95rem;">@customer.CompanyName</h5>
                <p class="text-muted small mb-2" style="font-size: 0.72rem;">Customer Identity Index Code: <span class="fw-bold text-secondary">@customer.Id</span></p>
                <span class="badge bg-success p-1 mb-3" style="font-size: 0.65rem;">Account: @customer.AccountStatus</span>

                <div class="row g-2 border-top pt-2.5" style="font-size: 0.8rem; line-height: 1.6;">
                    <div class="col-7 text-muted">Primary Contact:</div>
                    <div class="col-5 text-end fw-bold text-dark truncate-text">@customer.ContactName</div>

                    <div class="col-6 text-muted">Outstanding Balance:</div>
                    <div class="col-6 text-end fw-bold text-danger">@customer.BalanceDue.ToString("C")</div>

                    <div class="col-6 text-muted">Authorized Credit Limit:</div>
                    <div class="col-6 text-end fw-bold text-dark">@customer.CreditLimit.ToString("C")</div>

                    <div class="col-6 text-muted">Available Credit Room:</div>
                    <div class="col-6 text-end fw-bold text-primary">@customer.AvailableCredit.ToString("C")</div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning small p-2">No active database metrics mapped for this profile context.</div>
    }
</div>

@code {
    private void GoBack() => Nav.NavigateTo($"/dashboard{Nav.ToAbsoluteUri(Nav.Uri).Query}");
}

