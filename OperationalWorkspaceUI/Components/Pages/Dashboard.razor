@page "/dashboard"
@using OperationalWorkspaceUI.UIState
@using OperationalWorkspaceUI.UIServices
@using OperationalWorkspaceUI.Components.Shared
@using OperationalWorkspaceApplication.Dtos
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using OperationalWorkspaceApplication.Responses.WorkspaceContextResponse
@inject UIStateContainer StateContainer
@inject IWorkspaceApiService ApiService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@implements IDisposable
@rendermode InteractiveServer

<div class="dashboard-viewport container p-2">

    <!-- Context Header Component -->
    <header class="card border p-2 mb-2 bg-white shadow-xs rounded" role="banner">
        <div class="d-flex align-items-center">
            <div class="me-2 context-header-avatar" aria-hidden="true">📧</div>
            <div class="truncate-text col-10">
                <h1 class="m-0 text-header">@StateContainer.SenderName</h1>
                <small class="text-muted text-small" aria-label="Sender email address">@StateContainer.SenderEmail</small>
            </div>
        </div>
    </header>

    <!-- Section 9: Integrated Offline Resiliency Check Layout Array Markers -->
    @if (_isDeviceOffline || _isOperationPending || !string.IsNullOrEmpty(_uiActionErrorAlert))
    {
        <!-- Phase 10 Polish: Passing progressive status messages instead of static strings -->
        <ActionableFeedbackCard IsOffline="_isDeviceOffline"
                                IsLoading="_isOperationPending"
                                LoadingMessage="@_currentProgressiveStatusText"
                                ErrorMessage="@_uiActionErrorAlert"
                                OnRetryCallback="ForceOnDemandLedgerSync" />
    }

    <!-- Business Partner Customer 360 Analytical Financial Module Grid Layout -->
    @if (StateContainer.CurrentContextResponse?.Customer != null && !_isOperationPending)
    {
        var bp = StateContainer.CurrentContextResponse.Customer;
        <section class="card border mb-2 bg-white rounded shadow-sm" aria-label="Sage X3 Account Financial Standing metrics">
            <div class="card-header bg-dark text-white p-2 d-flex justify-content-between align-items-center">
                <span class="text-caption text-white">💼 Sage X3 Business Partner</span>
                <StatusBadge Value="@bp.AccountStatus" />
            </div>
            <div class="card-body p-2 bp-card-body">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <h2 class="text-header m-0 col-9 truncate-text">@bp.CompanyName</h2>

                    <!-- Phase 8 Resolution: Direct Enterprise Deep-Link Navigation Anchor to Sage X3 Client -->
                    <a href="@BuildSageX3CustomerDeepLink(bp.Id)"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="badge bg-primary text-decoration-none text-white text-caption"
                       aria-label="Open this customer master profile record inside native Sage X3 client">
                        🔗 Open X3
                    </a>
                </div>
                <div class="text-muted text-small">Account Tracking Token ID: <span class="text-dark fw-bold" aria-label="Business partner code identifier">@bp.Id</span></div>

                <hr class="my-2 bp-card-hr" />

                <div class="row g-1 text-center" role="group" aria-label="Credit Exposure Metrics Summary">
                    <div class="col-4 border-end">
                        <div class="text-caption">Credit Limit</div>
                        <div class="fw-bold text-dark text-small" aria-label='Total allocation limit: @bp.CreditLimit.ToString("C0")'>@bp.CreditLimit.ToString("C0")</div>
                    </div>
                    <div class="col-4 border-end">
                        <div class="text-caption">Balance Due</div>
                        <div class="fw-bold text-danger text-small" aria-label='Active balance due: @bp.BalanceDue.ToString("C0")'>@bp.BalanceDue.ToString("C0")</div>
                    </div>
                    <div class="col-4">
                        <div class="text-caption">Available</div>
                        <div class="fw-bold text-success text-small" aria-label='Remaining margin capacity: @bp.AvailableCredit.ToString("C0")'>@bp.AvailableCredit.ToString("C0")</div>
                    </div>
                </div>
            </div>
        </section>
    }

    <!-- High-Performance Virtualized and Accessible Document Ledger Logs Registry List Grid -->
    <section class="card border bg-white rounded shadow-sm mb-2" aria-label="Linked Documents Array Records Log list viewport">
        <h3 class="card-header bg-light p-2 text-caption text-secondary" id="doc-heading-label">
            📄 Financial Document Logs
        </h3>
        <div class="card-body p-0 document-list-scrollpane" role="list" aria-labelledby="doc-heading-label">
            @if (_isLazyLoadingDocuments)
            {
                <LoadingPanel Message="Progressively synchronizing secondary financial data tables..." />
            }
            else if (StateContainer.CurrentContextResponse?.RecentDocuments == null || !StateContainer.CurrentContextResponse.RecentDocuments.Any())
            {
                <!-- Phase 10 Polish: Dynamic context-aware empty-state component -->
                <EmptyStateView Message="No financial documents or recent ledger records found for this customer account." Icon="📄" />
            }
            else
            {
                <Virtualize Items="StateContainer.CurrentContextResponse.RecentDocuments" Context="doc">
                    <div class="compact-list-row d-flex justify-content-between align-items-center"
                         role="listitem"
                         aria-label='Document number @doc.DocumentNumber type @doc.Type created on @doc.Date.ToString("d") gross totals @doc.Amount @doc.Currency standing status flag @doc.Status'>
                        <div class="truncate-text col-7">
                            <!-- Phase 8 Resolution: Sub-resource operational Deep-Link for specific invoice document frames -->
                            <a href="@BuildSageX3DocumentDeepLink(doc.DocumentNumber, doc.Type)"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="fw-semibold text-primary text-small text-decoration-underline"
                               aria-label="Deep link view document details natively inside ERP screen">
                                @doc.DocumentNumber
                            </a>
                            <div class="text-muted text-caption document-caption-meta">@doc.Type | @doc.Date.ToLocalTime().ToString("d")</div>
                        </div>
                        <div class="text-end">
                            <span class="fw-bold text-secondary text-small me-2">@doc.Amount.ToString("N2") @doc.Currency</span>
                            <StatusBadge Value="@doc.Status" />
                        </div>
                    </div>
                </Virtualize>
            }
        </div>
    </section>

    <!-- Universal Corporate Navigation Operational Action Routing Command Panel Layouts -->
    @if (StateContainer.UserRoleScope.Contains("Admin"))
    {
        <nav class="admin-panel mt-2 border-top pt-2" role="navigation" aria-label="Administrative system operations routing navigation console options">
            <button class="btn btn-outline-dark btn-sm w-100 fw-bold py-1.5 shadow-xs text-small"
                    type="button"
                    aria-label="Navigate to browse system security global audit trail records registries"
                    @onclick="NavigateToAuditRegistry">
                📊 Open Global Ticket Audit Registry
            </button>
        </nav>
    }
</div>
@code {
    private bool _isOperationPending = false;
    private bool _isLazyLoadingDocuments = false;
    private string _uiActionErrorAlert = string.Empty;
    private bool _shouldRefreshLayoutState = true;
    private bool _isDeviceOffline = false;
    private static Action<MailItemChangedEventArgs>? _onMailItemSelectionChangedAction;

    // Phase 10 Polish: User indicator variables
    private string _currentProgressiveStatusText = "Authenticating secure identity context...";

    private const string SageX3ClientBaseUrl = "https://your-firm.com";

    protected override void OnInitialized()
    {
        StateContainer.OnStateChanged += HandleWorkspaceDataStateUpdated;
        _onMailItemSelectionChangedAction = HandleMailItemContextSwitched;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDeviceOffline = !await JSRuntime.InvokeAsync<bool>("eval", "navigator.onLine");
            _shouldRefreshLayoutState = true;
            StateHasChanged();
        }
    }

    protected override bool ShouldRender()
    {
        if (_shouldRefreshLayoutState)
        {
            _shouldRefreshLayoutState = false;
            return true;
        }
        return false;
    }

    private void HandleWorkspaceDataStateUpdated()
    {
        _shouldRefreshLayoutState = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable("NotifyMailItemSelectionChanged")]
    public static void NotifyMailItemSelectionChanged(MailItemChangedEventArgs args)
    {
        _onMailItemSelectionChangedAction?.Invoke(args);
    }

    private void HandleMailItemContextSwitched(MailItemChangedEventArgs args)
    {
        StateContainer.SetIdentityContext(args.SenderEmail, args.SenderName, StateContainer.ActiveUserEmail);
        _shouldRefreshLayoutState = true;
        InvokeAsync(ForceOnDemandLedgerSync);
    }

    private async Task ForceOnDemandLedgerSync()
    {
        if (_isDeviceOffline) return;

        _isOperationPending = true;
        _uiActionErrorAlert = string.Empty;

        // Phase 10 Progress Tracking: Step 1
        _currentProgressiveStatusText = "Authenticating secure identity credentials...";
        _shouldRefreshLayoutState = true;
        StateHasChanged();

        try
        {
            await Task.Delay(300); // UI thread breathing gap
            _currentProgressiveStatusText = "Resolving business partner context profiles...";
            StateHasChanged();

            // Phase 7 Resolution: Read the custom Result wrapper contract safely
            var result = await ApiService.GetWorkspaceContextAsync(StateContainer.SenderEmail, StateContainer.SenderName, StateContainer.ActiveUserEmail, "SIMULATED_USER_TOKEN");

            if (result != null && result.IsSuccess && result.Value != null)
            {
                var response = result.Value;

                var identityOnlyPayload = new WorkspaceContextResponse(response.Customer, new List<SageDocumentDto>(), response.AiExecutiveBrief, response.IsInternalEmployee, response.SuggestedNextActionCard, response.RecommendedActionStyleMarker);
                StateContainer.SetWorkspaceContextResponse(identityOnlyPayload);

                _isOperationPending = false;
                _shouldRefreshLayoutState = true;
                await InvokeAsync(StateHasChanged);

                if (response.Customer != null)
                {
                    _isLazyLoadingDocuments = true;
                    _shouldRefreshLayoutState = true;
                    StateHasChanged();

                    await Task.Delay(400);

                    var completePayload = new WorkspaceContextResponse(response.Customer, response.RecentDocuments, response.AiExecutiveBrief, response.IsInternalEmployee, response.SuggestedNextActionCard, response.RecommendedActionStyleMarker);
                    StateContainer.SetWorkspaceContextResponse(completePayload);
                }
            }
            else
            {
                // Phase 10 Polish: Mask raw network exceptions with clean business language
                _uiActionErrorAlert = "Unable to load customer information. Please verify network access or try again.";
            }
        }
        catch
        {
            _uiActionErrorAlert = "Sage X3 is currently unavailable. Stored workspace operations will remain active.";
        }
        finally
        {
            _isOperationPending = false;
            _isLazyLoadingDocuments = false;
            _shouldRefreshLayoutState = true;
            StateHasChanged();
        }
    }

    // Helper functions to compile clean native corporate web client deep-links
    private string BuildSageX3CustomerDeepLink(string customerId) =>
        $"{SageX3ClientBaseUrl}#function=GESBPC&mode=2&key={Uri.EscapeDataString(customerId)}";

    private string BuildSageX3DocumentDeepLink(string docNo, string type)
    {
        string functionCode = type.Contains("Invoice", StringComparison.OrdinalIgnoreCase) ? "GESSIH" : "GESSOH";
        return $"{SageX3ClientBaseUrl}#function={functionCode}&mode=2&key={Uri.EscapeDataString(docNo)}";
    }

    private void NavigateToAuditRegistry()
    {
        var currentQuery = Nav.ToAbsoluteUri(Nav.Uri).Query;
        Nav.NavigateTo($"/ticket-report{currentQuery}");
    }

    public void Dispose()
    {
        StateContainer.OnStateChanged -= HandleWorkspaceDataStateUpdated;
    }

    public class MailItemChangedEventArgs
    {
        public string SenderEmail { get; set; } = string.Empty;
        public string SenderName { get; set; } = string.Empty;
        public string MessageId { get; set; } = string.Empty;
    }
}
