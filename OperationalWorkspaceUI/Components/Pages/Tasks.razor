@page "/tasks"
@using OperationalWorkspaceUI.UIState
@using OperationalWorkspaceUI.UIServices

@using OperationalWorkspaceUI.Components.Shared
@using OperationalWorkspaceApplication.Requests.TicketRequest
@inject UIStateContainer StateContainer
@inject IWorkspaceApiService ApiService
@inject NavigationManager Nav
@implements IDisposable
@rendermode InteractiveServer

<div class="tasks-panel p-2">
    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
        <h6 class="m-0 fw-bold text-dark text-header" style="font-size: var(--font-size-header, 0.9rem);">📋 Tasks & Incident Entry</h6>
        <button class="btn btn-outline-secondary btn-sm py-0 px-2 text-small" style="font-size: var(--font-size-small, 0.72rem);" @onclick="GoBack">Back</button>
    </div>

    <!-- Protected Action Security Rule Block Validation -->
    @if (StateContainer.UserRoleScope.Contains("Admin") || StateContainer.UserRoleScope.Contains("Sales") || StateContainer.UserRoleScope.Contains("Consultant"))
    {
        <div class="card p-3 border shadow-sm bg-white mb-3">
            <div class="form-group mb-2">
                <label class="small fw-bold text-muted mb-1 text-caption">Incident Action / Complaint Title</label>
                <input class="form-control form-control-sm text-small" placeholder="Brief subject line description..." @bind="_model.Subject" />
            </div>
            <div class="form-group mb-2">
                <label class="small fw-bold text-muted mb-1 text-caption">Operational Elaborations</label>
                <textarea class="form-control form-control-sm text-small" placeholder="Detailed notes..." @bind="_model.Description" rows="3"></textarea>
            </div>

            <!-- Consolidated Feedback State Handler Reuses your Shared components -->
            @if (_model.IsSubmitting || !string.IsNullOrEmpty(_uiActionErrorAlert))
            {
                <ActionableFeedbackCard IsLoading="_model.IsSubmitting"
                                        LoadingMessage="Transmitting secure incident tracking envelope to Sage..."
                                        ErrorMessage="@_uiActionErrorAlert" />
            }

            @if (!string.IsNullOrEmpty(_model.SuccessFeedbackMessage))
            {
                <div class="alert alert-success p-2 small mb-2 text-small" style="font-size: var(--font-size-small, 0.72rem); border-radius: 4px;">
                    <strong>✔ Registered:</strong> @_model.SuccessFeedbackMessage
                </div>
            }

            <button class="btn btn-primary btn-sm w-100 fw-bold text-small mt-1"
                    style="font-size: 0.75rem;"
                    @onclick="SubmitTaskForm"
                    disabled="@(_model.IsSubmitting || string.IsNullOrWhiteSpace(_model.Subject))">
                <span>🔒 Securely Post to Sage Registry</span>
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-warning small p-2 text-small" style="border-radius: 6px;">
            ⚠️ PipelineWriteAccess Denied. Your Sage role scope does not authorize filing tracking cards.
        </div>
    }
</div>
@code {
    private TicketSubmissionViewModel _model = new();
    private string _uiActionErrorAlert = string.Empty;

    protected override void OnInitialized()
    {
        // Subscribe to state notifications cleanly to keep data fields synchronized
        StateContainer.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SubmitTaskForm()
    {
        _model.IsSubmitting = true;
        _model.SuccessFeedbackMessage = string.Empty;
        _uiActionErrorAlert = string.Empty;

        var cmd = new CreateTicketCommand(
            StateContainer.CurrentContextResponse?.Customer?.Id ?? "UNKNOWN_BP",
            _model.Subject,
            _model.Description,
            "Mail Body Context Extraction",
            "MSG-ID-881",
            StateContainer.ActiveUserEmail
        );

        // Execute asynchronous call wrapping responses inside Result pattern
        var res = await ApiService.SubmitIncidentTicketAsync(cmd, "MOCK_USER_TOKEN");

        // FIX: Verify result success status AND extract business values out of .Value payload safely
        if (res != null && res.IsSuccess && res.Value != null)
        {
            var payload = res.Value;

            _model.SuccessFeedbackMessage = $"Reference Code Token ID: {payload.TicketId} (Assigned Priority: {payload.AssignedPriority})";
            _model.Subject = string.Empty;
            _model.Description = string.Empty;
        }
        else
        {
            // Read business-level error feedback text fields straight from the failure contract
            _uiActionErrorAlert = res?.ErrorMessage ?? "Unable to log the requested incident ticket. Please try again.";
        }

        _model.IsSubmitting = false;
    }

    private void GoBack() => Nav.NavigateTo($"/dashboard{Nav.ToAbsoluteUri(Nav.Uri).Query}");

    public void Dispose()
    {
        // Phase 4 Resolution: Detach listener hook to completely eliminate memory leak vectors
        StateContainer.OnStateChanged -= HandleStateChanged;
    }

    // Isolated tracking container class mapping layout fields
    public class TicketSubmissionViewModel
    {
        public string Subject { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public bool IsSubmitting { get; set; } = false;
        public string SuccessFeedbackMessage { get; set; } = string.Empty;
    }
}
